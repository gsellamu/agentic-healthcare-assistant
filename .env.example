# Copy to .env and fill in. With no key the app runs fully offline (MockLLM).
# NEVER commit your real .env — it is git-ignored.

ANTHROPIC_API_KEY=                 # blank = offline mock; paste a key for real Claude
HCASST_MODEL=claude-opus-4-8
HCASST_OFFLINE=false               # true forces offline even if a key is set
HCASST_USE_ST_EMBEDDINGS=true      # SentenceTransformer embeddings; false = hashing fallback
HCASST_ST_MODEL=all-MiniLM-L6-v2
HCASST_MAX_LOOPS=3                 # grounding regenerate-or-caveat limit
